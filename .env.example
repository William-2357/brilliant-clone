# Optional: enables the Firestore + Firebase Auth backend (cross-device sync).
# Without these, the app runs on the localStorage backend (single-device).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Phase 2 (AI dealer-coach). The OpenAI key is held SERVER-SIDE only — it is NEVER
# put in this file or the client bundle (anything VITE_* ships to the browser).
#
# Free, no Blaze plan: deploy the Cloudflare Worker in worker/ and point the client
# at it. The key lives in a Worker secret, not here:
#   npm run coach:deploy
#   npx wrangler secret put OPENAI_API_KEY -c worker/wrangler.jsonc
# Then set the Worker URL below (or http://localhost:8787 for `npm run coach:dev`
# during local dev). Leave blank to run the app with no AI coach.
# See worker/README.md for the full setup.
VITE_COACH_ENDPOINT=
