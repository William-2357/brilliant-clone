# Test mode — used by `vite --mode test` (the `dev:test` script Playwright starts).
# Blanking the Firebase vars makes src/lib/backend.ts fall back to the localStorage
# backend, so end-to-end runs are deterministic, offline, and never touch the real
# Firebase project. These are intentionally empty (no secrets) and committed.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
